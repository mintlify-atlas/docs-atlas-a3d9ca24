  "keyFeatures": [
    "Custom NoSQL database language with intuitive syntax",
    "Full-featured Swing-based IDE with code editor and drag-and-drop support",
    "JFlex lexical analyzer with comprehensive token recognition",
    "CUP parser for syntactic analysis and error reporting",
    "In-memory database with automatic JSON persistence",
    "Support for complex data types (int, float, string, bool, array, object)",
    "Filter expressions with relational and logical operators",
    "Real-time error reporting with line/column information",
    "Export query results to JSON format"
  ],
  "publicApiSurface": [
    "DATABASE name STORE AT \"path.json\";",
    "USE database_name;",
    "TABLE table_name { field:type, ... };",
    "ADD table_name { field:value, ... };",
    "READ table_name FIELDS field1, field2 FILTER expression;",
    "UPDATE table_name SET field=value FILTER expression;",
    "CLEAR table_name;",
    "EXPORT \"output.json\";",
    "Interprete.crearBaseDatos(String, String)",
    "Interprete.usarBaseDatos(String)",
    "Interprete.insertarRegistro(String, Map)",
    "Interprete.leerTabla(String, List, String)",
    "Interprete.actualizarRegistros(String, Map, String)",
    "Lexer.yylex()",
    "Parser.parse()",
    "BaseDatos.agregarTabla(Tabla)",
    "Tabla.agregarRegistro(Registro)",
    "Registro.setCampo(String, Object)"
  ]
